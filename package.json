{
  "name": "motto",
  "displayName": "红星领航",
  "description": "用习近平新时代中国特色社会主义思想指引 AI 助手思考提示语，助力国企数字化转型。",
  "version": "0.1.0",
  "publisher": "Cyvadra",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "chat",
    "agent",
    "thinking",
    "phrases",
    "motto"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "motto.applyPhrases",
        "title": "红星领航：应用习近平语录到 AI 思考提示语"
      },
      {
        "command": "motto.resetPhrases",
        "title": "红星领航：恢复默认 AI 思考提示语"
      }
    ],
    "configuration": {
      "title": "红星领航",
      "properties": {
        "motto.autoApply": {
          "type": "boolean",
          "default": true,
          "description": "启动时自动将习近平语录应用到 AI 思考提示语。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  }
}
