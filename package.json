{
  "name": "motto",
  "displayName": "ThePilot",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "Cyvadra",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cyvadra/motto.git"
  },
  "engines": {
    "vscode": "^1.121.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "chat",
    "agent",
    "thinking",
    "phrases",
    "motto"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "motto.applyPhrases",
        "title": "%command.apply.title%"
      },
      {
        "command": "motto.resetPhrases",
        "title": "%command.reset.title%"
      }
    ],
    "configuration": {
      "title": "ThePilot",
      "properties": {
        "motto.autoApply": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoApply.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  }
}
